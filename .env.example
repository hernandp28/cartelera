# ─────────────────────────────────────────────────────────────
# Mundial 2026 — Cartelera & Motor Predictivo
# Copiá este archivo a `.env` y completá los valores.
# ─────────────────────────────────────────────────────────────

# --- Proveedor de datos: "apifootball" | "thesportsdb" | "sportmonks" | "seed" ---
DATA_PROVIDER=apifootball

# --- API-Football v3 (proveedor principal) ---
# Acceso directo api-sports.io; la key va en el header x-apisports-key.
# 👉 Pegá tu API key Pro acá:
APIFOOTBALL_API_KEY=0636ff010d9a6ce1ed3eb8ba8f205bd3
APIFOOTBALL_BASE_URL=https://v3.football.api-sports.io
APIFOOTBALL_LEAGUE_ID=1       # FIFA World Cup
APIFOOTBALL_SEASON=2026
APIFOOTBALL_FRIENDLIES_LEAGUE_ID=10   # Amistosos de selecciones
APIFOOTBALL_INCLUDE_FRIENDLIES=true
APIFOOTBALL_RATE_LIMIT_PER_MIN=300
# Tope de partidos por día (los EN VIVO/finalizados tienen prioridad)
AGENDA_MAX_MATCHES=10

# --- TheSportsDB (alternativo) ---
THESPORTSDB_API_KEY=3
THESPORTSDB_BASE_URL=https://www.thesportsdb.com/api/v1/json
THESPORTSDB_LEAGUE_ID=4429
THESPORTSDB_SEASON=2026
THESPORTSDB_RATE_LIMIT_PER_MIN=100
THESPORTSDB_FRIENDLIES_LEAGUE_ID=4562
THESPORTSDB_INCLUDE_FRIENDLIES=true

# --- Sportmonks (proveedor alternativo) ---
# Plan gratuito: solo Superliga (DK) y Scottish Premiership; el Mundial (732)
# requiere plan pago. Solo se usa si DATA_PROVIDER=sportmonks.
SPORTMONKS_API_TOKEN=
SPORTMONKS_BASE_URL=https://api.sportmonks.com/v3/football
SPORTMONKS_LEAGUE_ID=732
SPORTMONKS_RATE_LIMIT_PER_HOUR=180

# --- Zona horaria de visualización (todos los horarios en hora Argentina) ---
DISPLAY_TIMEZONE=America/Argentina/Buenos_Aires

# --- Fuente de datos de la cartelera: "auto" | "seed" | "live" ---
# auto  = intenta Sportmonks; si no hay acceso/datos cae al seed DEMO.
# seed  = siempre el seed DEMO del Mundial 2026.
# live  = siempre Sportmonks (falla si no hay acceso).
CARTELERA_SOURCE=auto

# --- Base de datos ---
POSTGRES_USER=mundial
POSTGRES_PASSWORD=mundial
POSTGRES_DB=mundial2026
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://mundial:mundial@db:5432/mundial2026

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- Noticias (opcionales; sin esto el motor de noticias queda en modo stub) ---
NEWSAPI_KEY=
GDELT_ENABLED=true

# --- App ---
API_CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
